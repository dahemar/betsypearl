---
import '@fontsource/manrope/latin-400.css';
import '@fontsource/manrope/latin-500.css';
import '@fontsource/ibm-plex-mono/latin-400.css';
import manrope400Woff2 from '@fontsource/manrope/files/manrope-latin-400-normal.woff2?url';
import manrope500Woff2 from '@fontsource/manrope/files/manrope-latin-500-normal.woff2?url';
import ibmPlexMono400Woff2 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { navLinks, siteMeta } from '../data/site';

const { title = siteMeta.name, description = siteMeta.description } = Astro.props;
const pageTitle = title === siteMeta.name ? title : `${title} | ${siteMeta.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <link rel="preload" href={manrope400Woff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={manrope500Woff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={ibmPlexMono400Woff2} as="font" type="font/woff2" crossorigin />
    {navLinks.map((link) => (
      <link rel="prefetch" href={link.href} />
    ))}
    <link rel="prefetch" href="/" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-frame">
      <Nav currentPath={Astro.url.pathname} />
      <main class="page-shell">
        <slot />
      </main>
    </div>
    <script>
      (() => {
        const anchors = document.querySelectorAll('a[href]');
        anchors.forEach((anchor) => {
          const href = anchor.getAttribute('href');
          if (!href || href.startsWith('/') || href.startsWith('#') || href.startsWith('mailto:')) {
            return;
          }
          if (!anchor.hasAttribute('target')) {
            anchor.setAttribute('target', '_blank');
            anchor.setAttribute('rel', 'noreferrer noopener');
          }
        });
      })();
    </script>
  </body>
</html>